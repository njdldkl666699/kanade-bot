ENVIRONMENT=prod
LOG_LEVEL=DEBUG

DRIVER=~fastapi
HOST=127.0.0.1
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

# 机器人昵称列表，以在此列表中的昵称开头的消息将被视为to_me消息。
NICKNAME=["宵崎奏"]

# 超级管理员列表，user是console适配器的默认用户。
SUPERUSERS=["user"]

# Console 适配器
CONSOLE_STRICT_TOME=true

## 插件配置

# LocalStore 配置
LOCALSTORE_USE_CWD=true

# Chat Plugin
CHAT__MODEL="gpt-5-mini"
CHAT__SYSTEM_PROMPT_FILE="Kanade-v4.md"
CHAT__SESSION_PROMPT_BUFFER_MAX_SIZE=100

CHAT__RAG__QUERY_N_RESULTS=3
CHAT__RAG__DISTANCE_THRESHOLD=0.65
CHAT__RAG__COLLECTION_NAME="kanade_wiki_collection"
CHAT__RAG__DOCUMENT_FILE="kanade_wiki.json"
CHAT__RAG__EMBEDDING_TYPE="openai"
CHAT__RAG__OPENAI_MODEL="BAAI/bge-m3"

# Crystal Plugin
CRYSTAL__GACHA__SHOW_TRAINED=true
CRYSTAL__HARVEST__DAILY_POWER=10

# Fun Plugin
FUN__PLUS_ONE_THRESHOLD=4

# Help Plugin
HELP__WELCOME_IMAGE_FILE="welcome.gif"

# Music Plugin
MUSIC__PLAYLIST_LINK="https://blog.njdldkl666699.dpdns.org/playlists/"
MUSIC__AUDIO_PAGE_SIZE=10
MUSIC__LYRIC_DEFAULT_LENGTH=4

# Summary Plugin
SUMMARY__MODEL="gpt-5-mini"
SUMMARY__SYSTEM_PROMPT_FILE="Summarizer.md"
SUMMARY__BOT_NAME="宵崎奏"
SUMMARY__MIN_SIZE=10
SUMMARY__MAX_SIZE=1024

# Status Plugin
# 触发插件功能的指令列表
PS_COMMAND=["状态", "status"]
# 是否回复目标用户
PS_REPLY_TARGET=False
# 需要进行测试响应速度的网址列表
PS_TEST_SITES=[{"name": "百度", "url": "https://www.baidu.com/"}]

# Whateat Plugin
WHATEAT_CD=0

## 其他配置
HF_ENDPOINT="https://hf-mirror.com"
# 生成JSON Schema
GENERATE_SCHEMAS=false

# Watchdog 配置
WATCHDOG__GITHUB_REPO="njdldkl666699/kanade-bot"
WATCHDOG__GITHUB_BRANCH="main"
WATCHDOG__POLL_INTERVAL=30
