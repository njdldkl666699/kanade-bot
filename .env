ENVIRONMENT=prod
LOG_LEVEL=DEBUG

DRIVER=~fastapi
HOST=127.0.0.1
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

# 机器人昵称列表，以在此列表中的昵称开头的消息将被视为to_me消息。
NICKNAME=["宵崎奏"]

# 超级管理员列表，user是console适配器的默认用户。
SUPERUSERS=["user"]

# Console 适配器
CONSOLE_STRICT_TOME=true

## 插件配置

# LocalStore 配置
LOCALSTORE_USE_CWD=true

# API60s Plugin
API60S_BASE_URL="https://60s.viki.moe"

# Chat Plugin
CHAT__MODEL="gpt-5-mini"
CHAT__SYSTEM_PROMPT_FILE="Kanade-v3.md"
CHAT__SESSION_PROMPT_BUFFER_MAX_SIZE=100

CHAT__CONFIG_FILE="chat_configs.json"
CHAT__FAIL_IMAGE_FILE="chat_fail.jpg"

CHAT__MEMES_DIR="memes/"
CHAT__MEMORIES_DIR="memories/"

CHAT__RAG_ENABLED=false
CHAT__RAG_PORT=39831
CHAT__RAG_QUERY_N_RESULTS=3
CHAT__RAG_DISTANCE_THRESHOLD=0.65

# Fun Plugin
FUN__CIALLO_IMAGE_FILE="宵崎奏Ciallo.webp"
FUN__PLUS_ONE_THRESHOLD=4
FUN__DUANZI_LIST_FILE="duanzi.json"

# Help Plugin
HELP__HARUKI_IMAGE_FILE="Haruki_help.png"

# Music Plugin
MUSIC__PLAYLIST_FILE="lx_list"
MUSIC__PLAYLIST_LINK="https://blog.njdldkl666699.dpdns.org/playlists/"

MUSIC__AUDIOS_DIR="sing_songs/"
MUSIC__AUDIO_PAGE_SIZE=10

MUSIC__LYRICS_DIR="lyrics/"
MUSIC__LYRIC_DEFAULT_LENGTH=4

# Summary Plugin
SUMMARY__MODEL="gpt-5-mini"
SUMMARY__SYSTEM_PROMPT_FILE="Summarizer.md"
SUMMARY__BOT_NAME="宵崎奏"
SUMMARY__MIN_SIZE=10
SUMMARY__MAX_SIZE=1024
SUMMARY__MESSAGE_RECORDS_FILE="summary_message_records.json"

# Tool Plugin
TOOL__FALLBACK_ICON_FILE="grass_block.png"
TOOL__TEMPLATE_FILE="mcstatus_template.html"
TOOL__SCHEDULE_CONFIGS_FILE="schedule_configs.json"

# Status Plugin
# 触发插件功能的指令列表
PS_COMMAND=["状态", "status"]
# 是否回复目标用户
PS_REPLY_TARGET=False
# 需要进行测试响应速度的网址列表
PS_TEST_SITES=[{"name": "百度", "url": "https://www.baidu.com/"}]

## 其他配置
HF_ENDPOINT="https://hf-mirror.com"
OPENAI_EMBED_PORT=21039

# RAG 服务端配置
RAG__PORT=39831
RAG__MODEL_NAME_OR_PATH="rag/bge-small-zh-v1.5/"
RAG__DB_DIR_PATH="rag/kanade_rag_db/"
RAG__DB_COLLECTION_NAME="kanade_wiki_collection"

# Watchdog 配置
WATCHDOG__GITHUB_REPO="njdldkl666699/kanade-bot"
WATCHDOG__GITHUB_BRANCH="main"
WATCHDOG__POLL_INTERVAL=30
