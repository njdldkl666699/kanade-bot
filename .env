ENVIRONMENT=prod

DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

NICKNAME=["Kanade", "小奏", "宵崎奏", "宵崎同学", "奏"]

# Console 适配器
CONSOLE_STRICT_TOME=true

# Chat Plugin
CHAT_MODEL=gpt-5-mini
CHAT_SYSTEM_MESSAGE_PATH="./Kanade.md"
CHAT_BAN_PATH="./chat_ban.json"

# API60s Plugin
API60S_BASE_URL="https://60s.viki.moe"

# APIHZ Plugin
APIHZ_API_URL="https://cn.apihz.cn/api"

# Fun Plugin
FUN_MUSIC_LIST_PATH="./lx_list_part_？？？"
FUN_MUSIC_LIST_LINK="https://blog.njdldkl666699.dpdns.org/playlists/"

# Help Plugin
HELP_LINK="https://www.bilibili.com/video/BV1GJ411x7h7/"

# Course Schedule Plugin
COURSE_REMINDER_ENABLED=false

# Status Plugin
SERVER_STATUS_ONLY_SUPERUSERS=false
SERVER_STATUS_TEMPLATE='
干 什 么 ！
CPU: {{ "%03d" % (cpu_usage*10) }}%
Memory: {{ "%03d" % (memory_usage.percent*10) }}%
Runtime: {{ runtime | relative_time | humanize_delta }}
{% if swap_usage.total %}Swap: {{ "%03d" % (swap_usage.percent*10) }}%{% endif %}
Disk:
{% for name, usage in disk_usage.items() %}
  {{ name }}: {{ "%02d" % usage.percent }}%
{% endfor %}
'