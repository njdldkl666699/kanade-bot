ENVIRONMENT=prod
LOG_LEVEL=DEBUG

DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

# 机器人昵称列表，以在此列表中的昵称开头的消息将被视为to_me消息。
NICKNAME=["Kanade", "小奏", "宵崎奏", "宵崎同学"]

# Console 适配器
CONSOLE_STRICT_TOME=true

HF_ENDPOINT="https://hf-mirror.com"
OPENAI_EMBED_PORT=21039

# Chat Plugin
CHAT_MODEL="gpt-5-mini"
CHAT_SYSTEM_PROMPT_FILE_PATH="assets/prompts/Kanade-v3.md"

CHAT_SESSION_PROMPT_BUFFER_MAX_SIZE=100
CHAT_CONFIG_FILE_PATH="assets/chat_configs.json"
CHAT_MEMES_DIR_PATH="assets/memes/"
CHAT_FAIL_IMAGE_FILE_PATH="assets/images/chat_fail.jpg"

CHAT_RAG_ENABLED=false
CHAT_RAG_PORT=39831
CHAT_RAG_QUERY_N_RESULTS=3
CHAT_RAG_DISTANCE_THRESHOLD=0.65

## RAG 服务端配置
CHAT_RAG_MODEL_OR_PATH="assets/bge-small-zh-v1.5/"
CHAT_RAG_DB_PATH="assets/kanade_rag_db/"
CHAT_RAG_DB_COLLECTION_NAME="kanade_wiki_collection"

# API60s Plugin
API60S_BASE_URL="https://60s.viki.moe"

# Fun Plugin
FUN_CIALLO_IMAGE_FILE_PATH="assets/images/宵崎奏Ciallo.webp"
FUN_PLUS_ONE_THRESHOLD=4

FUN_MUSIC_LIST_FILE_PATH="assets/lx_list"
FUN_MUSIC_LIST_LINK="https://blog.njdldkl666699.dpdns.org/playlists/"

FUN_SING_DIR_PATH="assets/sing_songs/"
FUN_SING_PAGE_SIZE=10

FUN_LYRICS_DIR_PATH="assets/lyrics/"

# Help Plugin
HELP_DOCS_DIR_PATH="assets/helps/"
HELP_IMAGES_CACHE_DIR_PATH="assets/help_images/"
HELP_SAKURA_BOT_LINK="https://help.mikuware.top"

# Tool Plugin
TOOL_FALLBACK_ICON_FILE_PATH="assets/images/grass_block.png"
TOOL_TEMPLATE_FILE_PATH="assets/mcstatus_template.html"

# Summary Plugin
SUMMARY_MODEL="gpt-5-mini"
SUMMARY_SYSTEM_PROMPT_FILE_PATH="assets/prompts/Summarizer.md"
SUMMARY_BOT_NAME="宵崎奏"
SUMMARY_MIN_SIZE=10
SUMMARY_MAX_SIZE=1024
SUMMARY_MESSAGE_RECORDS_FILE_PATH="assets/summary_message_records.json"