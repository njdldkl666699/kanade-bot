ENVIRONMENT=prod

DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

NICKNAME=["Kanade", "小奏", "宵崎奏", "宵崎同学", "奏"]

# Console 适配器
CONSOLE_STRICT_TOME=true

# Chat Plugin
CHAT_MODEL=gpt-4.1
CHAT_SYSTEM_MESSAGE_PATH="./Kanade.md"

# API60s Plugin
API60S_BASE_URL="https://60s.viki.moe"

# APIHZ Plugin
APIHZ_API_URL="https://cn.apihz.cn/api"

# Help Plugin
HELP_MARKDOWN_PATH="./help.md"
HELP_IMAGE_LIGHT_PATH="./help-light.png"
HELP_IMAGE_DARK_PATH="./help-dark.png"