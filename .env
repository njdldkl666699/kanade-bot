ENVIRONMENT=prod
LOG_LEVEL=DEBUG

DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
HOST=127.0.0.1
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

# 机器人昵称列表，以在此列表中的昵称开头的消息将被视为to_me消息。
NICKNAME=["Kanade", "小奏", "宵崎奏", "宵崎同学"]

# 超级管理员列表，user是console适配器的默认用户。
SUPERUSERS=["user"]

# Console 适配器
CONSOLE_STRICT_TOME=true

## 插件配置

# API60s Plugin
API60S_BASE_URL="https://60s.viki.moe"

# Chat Plugin
CHAT__MODEL="gpt-5-mini"
CHAT__SYSTEM_PROMPT_FILE_PATH="assets/prompts/Kanade-v3.md"

CHAT__SESSION_PROMPT_BUFFER_MAX_SIZE=100
CHAT__CONFIG_FILE_PATH="assets/chat_configs.json"
CHAT__MEMES_DIR_PATH="assets/memes/"
CHAT__FAIL_IMAGE_FILE_PATH="assets/images/chat_fail.jpg"
CHAT__MEMORIES_DIR_PATH="assets/memories/"

CHAT__RAG_ENABLED=false
CHAT__RAG_PORT=39831
CHAT__RAG_QUERY_N_RESULTS=3
CHAT__RAG_DISTANCE_THRESHOLD=0.65

# Fun Plugin
FUN__CIALLO_IMAGE_FILE_PATH="assets/images/宵崎奏Ciallo.webp"
FUN__PLUS_ONE_THRESHOLD=4

FUN__MUSIC_LIST_FILE_PATH="assets/lx_list"
FUN__MUSIC_LIST_LINK="https://blog.njdldkl666699.dpdns.org/playlists/"

FUN__SING_DIR_PATH="assets/sing_songs/"
FUN__SING_PAGE_SIZE=10

FUN__LYRICS_DIR_PATH="assets/lyrics/"

# Help Plugin
HELP__DOCS_DIR_PATH="assets/helps/"
HELP__IMAGES_CACHE_DIR_PATH="assets/help_images/"
HELP__HARUKI_IMAGE_FILE_PATH="assets/images/Haruki_help.png"

# Tool Plugin
TOOL__FALLBACK_ICON_FILE_PATH="assets/images/grass_block.png"
TOOL__TEMPLATE_FILE_PATH="assets/mcstatus_template.html"
TOOL__SCHEDULE_CONFIGS_FILE_PATH="assets/schedule_configs.json"

# Summary Plugin
SUMMARY__MODEL="gpt-5-mini"
SUMMARY__SYSTEM_PROMPT_FILE_PATH="assets/prompts/Summarizer.md"
SUMMARY__BOT_NAME="宵崎奏"
SUMMARY__MIN_SIZE=10
SUMMARY__MAX_SIZE=1024
SUMMARY__MESSAGE_RECORDS_FILE_PATH="assets/summary_message_records.json"

# Status Plugin
# 触发插件功能的指令列表
PS_COMMAND=["状态", "status"]
# 是否回复目标用户
PS_REPLY_TARGET=False
# 需要进行测试响应速度的网址列表
PS_TEST_SITES='
[
    {"name": "百度", "url": "https://www.baidu.com/"},
]
'

## 其他配置
HF_ENDPOINT="https://hf-mirror.com"
OPENAI_EMBED_PORT=21039

# RAG 服务端配置
RAG_MODEL_OR_PATH="assets/bge-small-zh-v1.5/"
RAG_DB_PATH="assets/kanade_rag_db/"
RAG_DB_COLLECTION_NAME="kanade_wiki_collection"

# Watchdog 配置
WATCHDOG_GITHUB_REPO="njdldkl666699/kanade-bot"
WATCHDOG_GITHUB_BRANCH="main"
WATCHDOG_POLL_INTERVAL=30