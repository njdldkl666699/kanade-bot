ENVIRONMENT=prod

DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

NICKNAME=["Kanade", "小奏", "宵崎奏", "宵崎同学", "奏"]

# Console 适配器
CONSOLE_STRICT_TOME=true

# Chat Plugin
CHAT_MODEL=gpt-4o
CHAT_SYSTEM_MESSAGE_PATH="./Kanade.md"
