ENVIRONMENT=prod

DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

# 机器人昵称列表，以在此列表中的昵称开头的消息将被视为to_me消息。
NICKNAME=["Kanade", "小奏", "宵崎奏", "宵崎同学", "奏"]

# Console 适配器
CONSOLE_STRICT_TOME=true

# Chat Plugin
CHAT_MODEL=gpt-5-mini
CHAT_SYSTEM_PROMPT_PATH="Kanade-v2.md"
CHAT_PROMPT_BUFFER_SIZE=-1
CHAT_BAN_PATH="chat_ban.json"

# API60s Plugin
API60S_BASE_URL="https://60s.viki.moe"

# APIHZ Plugin
APIHZ_API_URL="https://cn.apihz.cn/api"

# Fun Plugin
FUN_CIALLO_IMAGE_PATH="宵崎奏Ciallo.webp"
FUN_MUSIC_LIST_PATH="lx_list"
FUN_MUSIC_LIST_LINK="https://blog.njdldkl666699.dpdns.org/playlists/"

# Help Plugin
HELP_LINK="https://blog.njdldkl666699.dpdns.org/2026/03/18/Kanade-Bot-%E5%B8%AE%E5%8A%A9%E6%96%87%E6%A1%A3/"

# Course Schedule Plugin
COURSE_REMINDER_ENABLED=false