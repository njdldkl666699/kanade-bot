ENVIRONMENT=prod

DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
PORT=39210

COMMAND_START=["/"]
COMMAND_SEP=[" "]

# 机器人昵称列表，以在此列表中的昵称开头的消息将被视为to_me消息。
NICKNAME=["Kanade", "小奏", "宵崎奏", "宵崎同学"]

# Console 适配器
CONSOLE_STRICT_TOME=true

HF_ENDPOINT="https://hf-mirror.com"

# Chat Plugin
CHAT_MODEL=gpt-5-mini
CHAT_SYSTEM_PROMPT_PATH="assets/Kanade-v3.md"

CHAT_SESSION_PROMPT_BUFFER_MAX_SIZE=100
CHAT_CONFIG_PATH="chat_configs.json"
CHAT_MEMES_PATH="assets/memes"
CHAT_FAIL_IMAGE_PATH="assets/chat_fail.jpg"

CHAT_RAG_PORT=39831

# RAG 客户端配置
CHAT_RAG_ENABLED=false
CHAT_RAG_QUERY_N_RESULTS=3
CHAT_RAG_DISTANCE_THRESHOLD=0.65

# RAG 服务端配置
CHAT_RAG_MODEL_OR_PATH="assets/bge-small-zh-v1.5"
CHAT_RAG_DB_PATH="assets/kanade_rag_db"
CHAT_RAG_DB_COLLECTION_NAME="kanade_wiki_collection"

# API60s Plugin
API60S_BASE_URL="https://60s.viki.moe"

# Fun Plugin
FUN_CIALLO_IMAGE_PATH="assets/宵崎奏Ciallo.webp"
FUN_PLUS_ONE_THRESHOLD=4

FUN_MUSIC_LIST_PATH="assets/lx_list"
FUN_MUSIC_LIST_LINK="https://blog.njdldkl666699.dpdns.org/playlists/"

FUN_SING_DIRECTORY="assets/sing_songs"
FUN_SING_PAGE_SIZE=10

FUN_LYRICS_DIRECTORY="assets/lyrics"

# Help Plugin
HELP_DOC_PATH="assets/Kanade-Bot-帮助文档.md"
HELP_PIC_CACHE_DIR="assets/"

# Tool Plugin
TOOL_FONT_PATH="assets/unifont-17.0.04.otf"
TOOL_FALLBACK_ICON_PATH="assets/grass_block.png"

# Summary Plugin
SUMMARY_ENABLED=true
SUMMARY_MODEL="gpt-5-mini"
SUMMARY_SYSTEM_PROMPT_PATH="assets/Summarizer.md"
SUMMARY_MIN_SIZE=10
SUMMARY_MAX_SIZE=1024